<?xml version="1.0" encoding="utf-8"?>
<!--
  MSBuild Publish Profile — EC2 IIS Production (Windows Server)
  Safe to commit: contains no secrets.
  Produces a framework-dependent win-x64 folder at ../../../../publish/ec2/ relative to this file.
  Usage (from repo root):
    dotnet publish Insolvio.API/Insolvio.API.csproj /p:PublishProfile=EC2Production
-->
<Project>
  <PropertyGroup>
    <WebPublishMethod>FileSystem</WebPublishMethod>
    <PublishProvider>FileSystem</PublishProvider>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <SiteUrlToLaunchAfterPublish />
    <LaunchSiteAfterPublish>false</LaunchSiteAfterPublish>
    <ExcludeApp_Data>false</ExcludeApp_Data>
    <TargetFramework>net8.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishDir>$(MSBuildThisFileDirectory)..\..\..\..\publish\ec2\</PublishDir>
    <EnvironmentName>Production</EnvironmentName>
    <DeleteExistingFiles>true</DeleteExistingFiles>
    <!-- IIS uses web.config generated by publish — do not suppress it -->
    <!-- Exclude dev-only SPA proxy (triggers Vite dev server in development) -->
    <SpaProxyLaunchCommand></SpaProxyLaunchCommand>
  </PropertyGroup>
</Project>
