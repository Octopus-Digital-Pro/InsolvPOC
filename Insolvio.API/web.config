<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS web.config for Insolvio.API deployed on EC2 Windows Server.
  'dotnet publish' merges this file with the auto-generated AspNetCoreModule handler
  and <aspNetCore> element.  Do NOT add <aspNetCore> or <add name="aspNetCore"> here —
  the SDK owns those; merging them causes the processPath/arguments mismatch that
  produces "500 - Internal server error" on startup.

  This file only overrides IIS-level settings the SDK does not control:
    1. Remove WebDAVModule — otherwise IIS intercepts all PUT/DELETE verbs and
       returns 405 before the request reaches the ASP.NET Core pipeline.
    2. Raise maxAllowedContentLength to 750 MB — IIS enforces its own 30 MB cap
       independently of the Kestrel limit; without this the ONRC CSV upload is
       aborted by IIS and the browser sees a connection reset.
-->
<configuration>
  <system.webServer>

    <!-- ── 1. Remove WebDAV so IIS passes PUT / DELETE to ASP.NET Core ────── -->
    <modules>
      <remove name="WebDAVModule" />
    </modules>
    <handlers>
      <remove name="WebDAV" />
    </handlers>

    <!-- ── 2. Allow request bodies up to 750 MB (ONRC CSV uploads) ────────── -->
    <security>
      <requestFiltering>
        <!-- 750 MB in bytes — must exceed the Kestrel limit of 700 MB -->
        <requestLimits maxAllowedContentLength="786432000" />
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>
