# Firebase (client-side, safe to expose) — used by legacy POC frontend
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# API URL — leave blank to use Vite proxy (/api -> localhost:5000)
# Set this in production to the full API URL, e.g. https://api.insolvex.com/api
VITE_API_URL=

# OpenAI -- set in Netlify dashboard only, NOT in .env
# OPENAI_API_KEY=sk-...
